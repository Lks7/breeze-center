# breeze-center root gitignore

# ============================================
# Frontend (web/)
# ============================================
web/node_modules/
web/dist/
web/.env*
web/.vite/
web/.cache/

# ============================================
# Backend (server/)
# ============================================
server/bin/
server/tmp/
server/.env*

# Go build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# ============================================
# Database
# ============================================
data/*.db
data/*.db-shm
data/*.db-wal
data/backup/

# ============================================
# Trellis
# ============================================
.trellis/.runtime/
.trellis/.developer

# ============================================
# Logs
# ============================================
*.log
logs/

# ============================================
# IDE & Editor
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# OS
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Temporary files
# ============================================
*.tmp
*.bak
*.backup
.temp/
