{
  "manifest_version": 3,
  "name": "Breeze Bookmark Capture",
  "description": "Capture current tabs into Breeze Center bookmark wall.",
  "version": "0.1.0",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Save to Breeze",
    "default_popup": "popup.html"
  }
}
